# ============================================================
# ROOT .gitignore — impstr
# ============================================================

# ── Android / Gradle ─────────────────────────────────────────
.gradle/
build/
*.iml
*.hprof

# Local SDK / config (never commit these)
local.properties

# ── Android Studio / IntelliJ ────────────────────────────────
.idea/
.DS_Store

# ── Native build artefacts ───────────────────────────────────
.externalNativeBuild/
.cxx/

# ── Build outputs ────────────────────────────────────────────
captures/
build_output.txt

# ── Release bundles / APKs (don't commit signed releases) ────
*.aab
*.apk
IMPSTR/app/release/
IMPSTR/app/build/

# ── Tools ────────────────────────────────────────────────────
# ktlint CLI binary committed to repo root — exclude from push
ktlint

# ── Resources: only keep public-facing docs + app icon ────────
# Exclude internal planning / design documents
Resources/CHANGELOG.md
Resources/GUIDE.md
Resources/LOGIC.md
Resources/icon.svg
Resources/icon_master.svg
Resources/implimentation_plan.md
Resources/impstr_complete_production_plan_v2.md
Resources/impstr_implementation_plan.md
Resources/impstr_logic_engagement_architecture_spec_v3.md

# Keep: Resources/README.md and Resources/icon_play_store.png
!Resources/README.md
!Resources/icon_play_store.png

# ── Always track .gitignore files ────────────────────────────
!.gitignore
!IMPSTR/.gitignore
!.idea/.gitignore
/Resources/screenshots
